    ch = chr(dec)
    ch_disp = repr(ch)[1:-1] if (dec < 32 or dec == 127) else ch
    rows.append({"Ch": ch_disp, "Hex": f"{dec:02X}", "Dec": dec})
df = pd.DataFrame(rows)

nblocks = 8
chunk = (len(df) + nblocks - 1) // nblocks  # ceil

blocks = []
